#!/usr/bin/env python3
"""
holon - CLI wrapper for Holon autonomous agentic coder
"""

import argparse
import os
import subprocess
import sys


def run_in_container(role: str, *args: str) -> None:
    """Run holon/<role> in a Docker container with appropriate mounts."""
    common_args = [
        "docker", "run", "--rm", "-it",
        "-v", f"{os.path.expanduser('~/.ssh')}:/home/holon/.ssh:ro",
        "-e", f"HOLON_ROLE={role}",
    ]

    if role == "intent-creator":
        host_json_path = os.path.realpath(args[0])
        container_args = common_args + [
            "-v", f"{host_json_path}:/tmp/intent.json:ro",
            "holon/orchestrator",
            *args[1:],
        ]
    else:
        container_args = common_args + [
            "holon/orchestrator",
            *args,
        ]

    subprocess.run(container_args, check=True)


def main():
    parser = argparse.ArgumentParser(
        prog="holon",
        description="CLI wrapper for Holon autonomous agentic coder",
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    # create-intent <json_file>
    sub_create = subparsers.add_parser(
        "create-intent",
        help="Create a new intent branch and log intent",
    )
    sub_create.add_argument(
        "json_file",
        help="Path to intent JSON file",
        type=os.path.realpath,
    )
    sub_create.set_defaults(func=lambda opts: run_in_container("intent-creator", opts.json_file))

    # plan <intent_branch> <agent_name> <model_name>
    sub_plan = subparsers.add_parser(
        "plan",
        help="Generate plan branches for an intent",
    )
    sub_plan.add_argument("intent_branch", help="Intent branch name")
    sub_plan.add_argument("agent_name", help="Agent name")
    sub_plan.add_argument("model_name", help="Model name")
    sub_plan.set_defaults(
        func=lambda opts: run_in_container(
            "planner", opts.intent_branch, opts.agent_name, opts.model_name
        )
    )

    # execute <plan_branch> <agent_name> <model_name> <action_slug>
    sub_exec = subparsers.add_parser(
        "execute",
        help="Execute an action on a plan branch",
    )
    sub_exec.add_argument("plan_branch", help="Plan branch name")
    sub_exec.add_argument("agent_name", help="Agent name")
    sub_exec.add_argument("model_name", help="Model name")
    sub_exec.add_argument("action_slug", help="Action slug")
    sub_exec.set_defaults(
        func=lambda opts: run_in_container(
            "executor", opts.plan_branch, opts.agent_name, opts.model_name, opts.action_slug
        )
    )

    opts = parser.parse_args()
    opts.func(opts)


if __name__ == "__main__":
    main()